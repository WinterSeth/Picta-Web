    "@schematics/angular": "^20.3.21",
    "@tailwindcss/postcss": "^4.2.2",
    "angularx-qrcode": "^20.0.0",
    "animate.css": "^4.1.1",
    "core-js": "^3.40.0",
    "date-fns": "^4.1.0",
    "express": "^4.18.2",
    "hls.js": "^1.6.2",
