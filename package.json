{
  "name": "picta",
  "version": "0.0.0",
  "prettier": {
    "bracketSameLine": true,
    "arrowParens": "avoid",
    "bracketSpacing": true,
    "jsxSingleQuote": true,
    "quoteProps": "as-needed",
    "semi": true,
    "singleQuote": true
  },
  "scripts": {
    "ng": "ng",
    "start": "ng serve --port=4211 --host 0.0.0.0 --configuration development",
    "start-prod": "ng serve --port=4211 --host 0.0.0.0 --configuration production",
    "start:es": "ng serve --aot --locale es",
    "build": "ng build",
    "build-prod": "ng build --configuration production",
    "build-dev": "ng build --configuration development",
    "build-run": "ng build --configuration production --aot&&cd dist&&lite-server",
    "test": "ng test",
    "lint": "ng lint",
    "e2e": "ng e2e"
  },
  "private": true,
  "dependencies": {
